# AdvancedMD API Credentials
ADVANCEDMD_USERNAME=your_username
ADVANCEDMD_PASSWORD=your_password
ADVANCEDMD_OFFICE_KEY=your_office_key
ADVANCEDMD_APP_NAME=your_app_name

# Upstash Redis (get from https://console.upstash.com/)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# API Security (generate random strings)
CRON_SECRET=random_secret_for_cron
API_SECRET=random_secret_for_token_endpoint
